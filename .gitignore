# Unity + XR Interaction Toolkit — root .gitignore
#
# Bases:
#   https://github.com/github/gitignore/blob/main/Unity.gitignore
#   XR / com.unity.xr.interaction.toolkit project template
#
# Global editor/OS templates: https://github.com/github/gitignore/tree/main/Global

# --- XR / first-launch ---
InitCodeMarker
/[Tt]utorial [Dd]efaults/

# --- UPM CI (packed templates) ---
upm-ci~/
upm-ci.log

# Never ignore Asset meta data
!/[Aa]ssets/**/*.meta

# --- Project / user settings (Settings Manager, Unity 2020.1+) ---
/ProjectSettings/Packages/
/[Uu]ser[Ss]ettings/

# --- Unity generated (cache, builds, logs) ---
/.Editor/
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
*.log

# MemoryCaptures can get excessive in size and may contain sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# XR Validation Suite
/[Vv]alidationSuiteResults/

# Asset Store tools plugin (re-import from Store)
/[Aa]ssets/AssetStoreTools*

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# --- IDE ---
.idea/
.vs/
.vscode/
.vsconfig

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Blender backup files (not needed in VCS)
*.blend1
*.blend1.meta

# --- Builds & packages ---
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics / merge artifacts
crashlytics-build.properties
*.orig
*.orig.meta

# Unity build reports
/[Aa]ssets/[Bb]uild[Rr]eports*

# Format tool backups
*.preformat.bak
*.preformat.bak.meta

# --- Test Runner ---
InitTestScene*.unity*
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# --- Addressables ---
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# --- Visual Scripting (auto-generated) ---
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated cache in Assets folder
/[Aa]ssets/[Ss]ceneDependencyCache*

# --- macOS ---
.DS_Store
**/.DS_Store

# --- Project-specific: third-party Asset Store packs ---
# Re-import from the Store; do not version (Nebula Skyboxes, Kevin Iglesias, etc.)
/[Aa]ssets/AssetPacks/
/[Aa]ssets/AssetPacks.meta

# --- Android/IL2CPP build artifacts (regenerated per build, never ship) ---
/*_BurstDebugInformation_DoNotShip/
