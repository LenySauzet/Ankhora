# Ankhora — Unity + cross-platform (Mac M4 Pro + Windows) line endings & LFS
#
# Two goals:
#   1) Force LF for every text file so Mac/Windows teammates do not generate
#      whitespace-only diffs on every commit.
#   2) Route every binary Unity-style asset through Git LFS so the repo stays
#      lean and `git clone` stays fast for new teammates.
#
# Reference baselines:
#   - https://github.com/github/gitignore (Unity.gitignore companion)
#   - Unity manual > Smart Merge / version control
#   - https://github.com/nemotoo/.gitattributes-Unity (community standard)

# --------------------------------------------------------------------
# Line endings — text files
# --------------------------------------------------------------------
# Auto-detect text, default to LF in the index.
* text=auto eol=lf

# Source code
*.cs        text eol=lf diff=csharp
*.shader    text eol=lf
*.cginc     text eol=lf
*.hlsl      text eol=lf
*.compute   text eol=lf
*.uss       text eol=lf
*.uxml      text eol=lf

# Project / package descriptors
*.json      text eol=lf
*.json5     text eol=lf
*.txt       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.md        text eol=lf
*.mdc       text eol=lf

# Shell + windows scripts keep their native endings
*.sh        text eol=lf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# --------------------------------------------------------------------
# Unity merge driver (run `git config merge.unityyamlmerge.driver ...`)
# Smart Merge keeps scene / prefab merges sane when 3 devs touch the same scene.
# Each teammate must register the driver locally once (documented in docs/05-operations/build-deploy.md).
# --------------------------------------------------------------------
*.unity     merge=unityyamlmerge eol=lf
*.prefab    merge=unityyamlmerge eol=lf
*.asset     merge=unityyamlmerge eol=lf
*.meta      merge=unityyamlmerge eol=lf
*.controller merge=unityyamlmerge eol=lf
*.anim      merge=unityyamlmerge eol=lf
*.mat       merge=unityyamlmerge eol=lf
*.physicMaterial merge=unityyamlmerge eol=lf
*.physicsMaterial2D merge=unityyamlmerge eol=lf
*.playable  merge=unityyamlmerge eol=lf
*.mask      merge=unityyamlmerge eol=lf
*.brush     merge=unityyamlmerge eol=lf
*.flare     merge=unityyamlmerge eol=lf
*.fontsettings merge=unityyamlmerge eol=lf
*.guiskin   merge=unityyamlmerge eol=lf
*.giparams  merge=unityyamlmerge eol=lf
*.renderTexture merge=unityyamlmerge eol=lf
*.spriteatlas merge=unityyamlmerge eol=lf
*.terrainlayer merge=unityyamlmerge eol=lf
*.mixer     merge=unityyamlmerge eol=lf
*.shadervariants merge=unityyamlmerge eol=lf

# --------------------------------------------------------------------
# Git LFS — binary assets
# Initialise once per clone: `git lfs install` and `git lfs pull`.
# --------------------------------------------------------------------

# Images
*.png       filter=lfs diff=lfs merge=lfs -text
*.jpg       filter=lfs diff=lfs merge=lfs -text
*.jpeg      filter=lfs diff=lfs merge=lfs -text
*.gif       filter=lfs diff=lfs merge=lfs -text
*.bmp       filter=lfs diff=lfs merge=lfs -text
*.tga       filter=lfs diff=lfs merge=lfs -text
*.tif       filter=lfs diff=lfs merge=lfs -text
*.tiff      filter=lfs diff=lfs merge=lfs -text
*.psd       filter=lfs diff=lfs merge=lfs -text
*.exr       filter=lfs diff=lfs merge=lfs -text
*.hdr       filter=lfs diff=lfs merge=lfs -text
*.iff       filter=lfs diff=lfs merge=lfs -text
*.pict      filter=lfs diff=lfs merge=lfs -text

